# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# Database
DATABASE_URL=your-database-url-here

# CORS/CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8000

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=hrglobaltechsoftwaresolutions@gmail.com
EMAIL_HOST_PASSWORD=your-email-password-here
DEFAULT_FROM_EMAIL=hrglobaltechsoftwaresolutions@gmail.com
FRONTEND_URL=https://globaltechsoftwaresolutions.cloud
LOGO_URL=https://www.globaltechsoftwaresolutions.com/_next/image?url=%2Flogo%2FGlobal.jpg&w=64&q=75

# MinIO
MINIO_ENDPOINT=minio.globaltechsoftwaresolutions.cloud:9000
MINIO_ACCESS_KEY=your-minio-access-key-here
MINIO_SECRET_KEY=your-minio-secret-key-here
MINIO_BUCKET_NAME=hrms-media
MINIO_USE_SSL=True
BASE_BUCKET_URL=https://minio.globaltechsoftwaresolutions.cloud:9000/hrms-media/

# Media
MEDIA_URL=/media/

# Firebase Configuration
# For production, use a secure path to the service account file
# For local development, use .env.local which contains actual credentials
FIREBASE_SERVICE_ACCOUNT_KEY=firebase-service-account.json